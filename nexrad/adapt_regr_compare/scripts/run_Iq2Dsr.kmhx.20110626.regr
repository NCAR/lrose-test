#! /bin/csh -f

# Run Iq2Dsr, writing moments data to fmq

cd $HOME/git/lrose-test/nexrad/adapt_regr_compare/params

setenv radar_name kmhx
setenv RADAR_NAME KMHX
setenv CASE_DATE 20110626
setenv DATA_DIR /scr/cirrus1/rsfdata/projects/nexrad

snuff "Dsr2Radx -params Dsr2Radx.regr"
Dsr2Radx -params Dsr2Radx.regr -debug >& /tmp/Dsr2Radx.regr.${radar_name}.${CASE_DATE}.log &
Iq2Dsr -params Iq2Dsr.regr -debug -f ${DATA_DIR}/time_series/kmhx/20110626/KMHX_RVP.20110626.095843.710.vcp21.1.H+V.460
